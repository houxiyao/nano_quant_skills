        "fcf",
        "interestdebt",
        "current_ratio",
        "debt_to_assets",
        "leverage_trend"
      ],
      "missing_data": [
        "annual_report_notes_text"
      ],
      "script": "look-05-balance-sheet-health/scripts/look_05_balance_sheet_health.py",
      "test_status": "passed",
      "review_status": "reviewed",
      "notes": "分析经营现金流覆盖、有息负债、偿债能力、资产负债率、隐性负债。隐性负债需要年报附注全文（human-in-loop）。金融类公司不适用。已拆分为独立 skill：look-05-balance-sheet-health。"
    },
    {
      "rule_id": "look-06",
      "sequence": 6,
      "category": "look",
